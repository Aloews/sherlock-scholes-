# Copy this file to ".env" (same folder) and fill in REAL values.
# ".env" is gitignored and must never be committed. This template is safe
# to share because it contains placeholders only — no real secrets.

# API-Football (api-sports.io) key — required for every run (dry-run too)
FOOTBALL_API_KEY=your_api_football_key_here

# Supabase project URL — required only for the real (non-dry-run) write
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/service key — required only for the real (non-dry-run) write
SUPABASE_KEY=your_supabase_key_here
